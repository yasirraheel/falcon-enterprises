<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="10dp">

    <!-- App Branding Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <!-- App Logo -->
        <ImageView
            android:id="@+id/iv_draft_logo"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="App Logo"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_draft_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FALCON ENTERPRISES"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_draft_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Online Booking"
            android:textSize="18sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/primary_color"
        android:layout_marginBottom="20dp" />

    <!-- Summary Card & Date Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Summary Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F8F9FA"
            android:layout_marginBottom="10dp">

            <!-- Blue Left Border -->
            <View
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:background="@color/primary_color" />

            <!-- Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_game_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game Category: All Categories"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_total_orders_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Orders: 0"
                    android:textSize="16sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_customer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Customer Name: -"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>
        </LinearLayout>

        <!-- Generated Date -->
        <TextView
            android:id="@+id/tv_generated_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generated on: Jan 24, 2026 at 5:11 AM"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="end"
            android:layout_marginBottom="4dp" />

    </LinearLayout>

</LinearLayout>