<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        style="@style/WidgetGeoTopBar">

        <ImageView
            android:id="@+id/iv_back"
            style="@style/WidgetGeoTopBarNavIcon"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <TextView
            style="@style/TextAppearanceGeoTopBarTitle"
            android:text="Bulk Order"
            />

        <!-- Dealer Badge -->
        <LinearLayout
            android:id="@+id/ll_dealer_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dealer"
                android:textSize="10sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.02"
                android:background="@drawable/bg_dealer_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:drawableStart="@drawable/ic_verified_small"
                android:drawablePadding="3dp" />

            <TextView
                android:id="@+id/tv_dealer_commission"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5%"
                android:textSize="10sp"
                android:textColor="#92400E"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_commission_badge"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginStart="6dp"
                android:gravity="center"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Game and Bond Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Game"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_game_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Game Name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bond"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_bond_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bond Name"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Order Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add Orders"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="8dp" />

                    <!-- RTTP Input (Bigger) -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RTTP (separate with dot . or new line)"
                        android:textSize="11sp"
                        android:textColor="@color/primary_color"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_rttp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="100dp"
                        android:background="@drawable/bg_input_dark_border"
                        android:hint="e.g. 1234 or 1234.5678.9012"
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:padding="12dp"
                        android:gravity="top|start"
                        android:layout_marginBottom="4dp"
                        android:minLines="3"
                        android:maxLines="10"
                        android:scrollbars="vertical" />

                    <TextView
                        android:id="@+id/tv_rttp_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/error"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp" />

                    <!-- RTTP Pattern Hints -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="📌 Single: 1234 | Multiple: 1234.5678.9012 | With +: 12+3 (Max 4 chars each)"
                        android:textSize="10sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp"
                        android:lineSpacingExtra="2dp" />

                    <!-- Game Type Info -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🎮 Supported: (#Open | #Akra | #Ring | #Forecast)"
                        android:textSize="10sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="12dp" />

                    <!-- First and Second Fields -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- First Field -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="First"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/et_first"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_input_dark_border"
                                android:hint="0"
                                android:inputType="number"
                                android:textSize="14sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:gravity="center" />

                        </LinearLayout>

                        <!-- Second Field -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Second"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="4dp" />

                            <EditText
                                android:id="@+id/et_second"
                                android:layout_width="match_parent"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_input_dark_border"
                                android:hint="0"
                                android:inputType="number"
                                android:textSize="14sp"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:gravity="center" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Add to Draft Button -->
                    <Button
                        android:id="@+id/btn_add_to_draft"
                        android:layout_width="match_parent"
                        android:layout_height="46dp"
                        android:text="Add to Draft"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Draft Orders Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Draft Orders"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tv_clear_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear All"
                            android:textSize="12sp"
                            android:textColor="@color/error"
                            android:padding="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:clickable="true"
                            android:focusable="true"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Table Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#F5F5F5"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:text="RTTP"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="First"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:gravity="end" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Second"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:gravity="end" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:gravity="end" />

                        <View
                            android:layout_width="36dp"
                            android:layout_height="1dp"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                    <!-- Draft Orders RecyclerView -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_draft_orders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false" />

                    <!-- Empty State -->
                    <TextView
                        android:id="@+id/tv_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:gravity="center"
                        android:text="No orders yet\nStart typing to preview"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:visibility="visible" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Summary Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Order Count & Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Orders"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tv_total_orders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grand Total"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tv_grand_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₨ 0"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_color" />

                        </LinearLayout>

                    </LinearLayout>
                    
                    <!-- Dealer Commission Info (Real-time) -->
                    <LinearLayout
                        android:id="@+id/ll_realtime_commission_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#E8F5E9"
                        android:padding="8dp"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="2dp">
                            
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="You will pay:"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                                
                            <TextView
                                android:id="@+id/tv_realtime_payable"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₨ 0"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/success_dark" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_realtime_commission_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="11sp"
                            android:textColor="@color/success_dark" />

                    </LinearLayout>

                    <!-- Export Name (shown before Export PDF) -->
                    <EditText
                        android:id="@+id/et_export_name"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Enter name for PDF"
                        android:inputType="textPersonName"
                        android:background="@drawable/bg_input_dark_border"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="8dp"
                        android:visibility="gone" />

                    <!-- Book All Button -->
                    <Button
                        android:id="@+id/btn_book_all"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Book All Orders"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/button_primary_background" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>

