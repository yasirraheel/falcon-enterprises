<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dialog_margin_horizontal"
    android:layout_marginRight="@dimen/dialog_margin_horizontal"
    android:layout_marginTop="@dimen/dialog_margin_vertical"
    android:layout_marginBottom="@dimen/dialog_margin_vertical"
    android:maxWidth="@dimen/dialog_max_width"
    app:cardCornerRadius="@dimen/dialog_corner_radius"
    app:cardElevation="@dimen/dialog_elevation"
    app:cardBackgroundColor="@color/white">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="@dimen/dialog_max_height"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/dialog_content_padding"
        android:paddingRight="@dimen/dialog_content_padding"
        android:paddingTop="@dimen/dialog_header_padding_vertical"
        android:paddingBottom="@dimen/dialog_header_padding_vertical"
        android:gravity="center_vertical"
        android:minHeight="@dimen/dialog_header_min_height">

        <ImageView
            android:layout_width="@dimen/dialog_header_icon_size"
            android:layout_height="@dimen/dialog_header_icon_size"
            android:src="@drawable/ic_arrow_forward"
            android:tint="@color/white"
            android:layout_marginEnd="@dimen/dialog_header_icon_margin"
            android:contentDescription="Share icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Share App"
            android:textColor="@color/white"
            android:textSize="@dimen/dialog_header_text_size"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="@dimen/dialog_content_padding"
        android:paddingRight="@dimen/dialog_content_padding"
        android:paddingTop="@dimen/dialog_content_padding"
        android:paddingBottom="@dimen/dialog_content_padding">

        <!-- App Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/dialog_section_spacing">

            <ImageView
                android:layout_width="@dimen/dialog_app_icon_size"
                android:layout_height="@dimen/dialog_app_icon_size"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="@dimen/dialog_app_icon_margin"
                android:contentDescription="App icon" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Falcon Enterprises"
                    android:textSize="@dimen/dialog_app_name_text_size"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_app_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0"
                    android:textSize="@dimen/dialog_app_version_text_size"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share this amazing app with your friends and family! Get the latest features and updates for prize bond booking and management."
            android:textSize="@dimen/dialog_description_text_size"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="@dimen/dialog_text_line_spacing"
            android:layout_marginBottom="@dimen/dialog_section_spacing"
            android:justificationMode="inter_word" />

        <!-- Update Info -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_update_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dialog_section_spacing"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/dialog_update_card_corner_radius"
            app:cardBackgroundColor="#E8F5E8"
            app:cardElevation="@dimen/dialog_update_card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/dialog_update_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚀 New Version Available!"
                    android:textSize="@dimen/dialog_update_title_text_size"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="@dimen/dialog_update_text_spacing"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_new_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Version 1.3 is now available"
                    android:textSize="@dimen/dialog_update_text_size"
                    android:textColor="#2E7D32"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_download_count"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Downloads: 0"
                    android:textSize="@dimen/dialog_update_count_text_size"
                    android:textColor="#2E7D32"
                    android:layout_marginTop="@dimen/dialog_update_text_spacing"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <LinearLayout
            android:id="@+id/layout_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="@dimen/dialog_button_margin_top">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/dialog_button_height"
                android:layout_weight="1"
                android:text="Cancel"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/dialog_button_text_size"
                android:layout_marginEnd="@dimen/dialog_button_spacing"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_copy_link"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/dialog_button_height"
                android:layout_weight="1"
                android:text="Copy"
                android:textColor="@color/primary_color"
                android:textSize="@dimen/dialog_button_text_size"
                app:strokeColor="@color/primary_color"
                app:cornerRadius="@dimen/dialog_button_corner_radius"
                app:icon="@drawable/ic_copy"
                app:iconTint="@color/primary_color"
                app:iconSize="@dimen/dialog_button_icon_size"
                android:layout_marginEnd="@dimen/dialog_button_spacing"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_share"
                android:layout_width="0dp"
                android:layout_height="@dimen/dialog_button_height"
                android:layout_weight="1"
                android:text="Share"
                android:textColor="@color/white"
                android:textSize="@dimen/dialog_button_text_size"
                android:backgroundTint="@color/primary_color"
                app:cornerRadius="@dimen/dialog_button_corner_radius"
                app:icon="@drawable/ic_arrow_forward"
                app:iconTint="@color/white"
                app:iconSize="@dimen/dialog_button_icon_size"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

</ScrollView>

</androidx.cardview.widget.CardView>