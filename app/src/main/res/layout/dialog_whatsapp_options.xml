<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#25D366">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_whatsapp"
            android:tint="@color/white"
            android:layout_marginBottom="10dp"
            android:contentDescription="WhatsApp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Join WhatsApp"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Choose how you want to connect"
            android:textSize="13sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/white">

        <!-- WhatsApp Chat Option -->
        <LinearLayout
            android:id="@+id/btn_whatsapp_chat"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F0FFF4"
            android:padding="12dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <!-- WhatsApp Green Circle Icon -->
            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="#25D366"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_whatsapp"
                    android:tint="@color/white"
                    android:contentDescription="Chat" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Chat"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B1B1B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chat directly with support"
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="#25D366"
                android:contentDescription="Go" />

        </LinearLayout>

        <!-- Join Group Option -->
        <LinearLayout
            android:id="@+id/btn_whatsapp_group"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#F0FFF4"
            android:padding="12dp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground">

            <!-- People Icon -->
            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="#128C7E"
                android:layout_marginEnd="14dp">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_person"
                    android:tint="@color/white"
                    android:contentDescription="Group" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join Group"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B1B1B" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Join our WhatsApp community"
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="#128C7E"
                android:contentDescription="Go" />

        </LinearLayout>

        <!-- Cancel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_wa_cancel"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="#666666"
            android:backgroundTint="#F0F0F0"
            android:textAllCaps="false"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

    </LinearLayout>

</LinearLayout>
