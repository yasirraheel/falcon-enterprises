<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="@dimen/dialog_margin_horizontal"
    android:layout_marginRight="@dimen/dialog_margin_horizontal"
    android:layout_marginTop="@dimen/dialog_margin_vertical"
    android:layout_marginBottom="@dimen/dialog_margin_vertical"
    android:maxWidth="@dimen/dialog_max_width"
    app:cardCornerRadius="@dimen/dialog_corner_radius"
    app:cardElevation="@dimen/dialog_elevation"
    app:cardBackgroundColor="@color/white">

<ScrollView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:maxHeight="@dimen/dialog_max_height"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        android:orientation="horizontal"
        android:paddingLeft="@dimen/dialog_content_padding"
        android:paddingRight="@dimen/dialog_content_padding"
        android:paddingTop="@dimen/dialog_header_padding_vertical"
        android:paddingBottom="@dimen/dialog_header_padding_vertical"
        android:gravity="center_vertical"
        android:minHeight="@dimen/dialog_header_min_height">

        <ImageView
            android:layout_width="@dimen/dialog_header_icon_size"
            android:layout_height="@dimen/dialog_header_icon_size"
            android:src="@drawable/ic_warning"
            android:tint="@color/white"
            android:layout_marginEnd="@dimen/dialog_header_icon_margin"
            android:contentDescription="Warning icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Update Required"
            android:textColor="@color/white"
            android:textSize="@dimen/dialog_header_text_size"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="@dimen/dialog_content_padding"
        android:paddingRight="@dimen/dialog_content_padding"
        android:paddingTop="@dimen/dialog_content_padding"
        android:paddingBottom="@dimen/dialog_content_padding">

        <!-- Update Icon -->
        <ImageView
            android:layout_width="@dimen/dialog_app_icon_size"
            android:layout_height="@dimen/dialog_app_icon_size"
            android:src="@drawable/ic_refresh"
            android:tint="@color/primary_color"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/dialog_section_spacing"
            android:contentDescription="Update icon" />

        <!-- Version Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Version"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_current_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/primary_color" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New Version"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_new_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color" />

            </LinearLayout>

        </LinearLayout>

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A new version of the app is available with important updates and bug fixes. Please update to continue using the app."
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:layout_marginBottom="16dp" />

        <!-- Release Notes -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_release_notes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:visibility="gone"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="@color/card_background"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="What's New:"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/tv_release_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Download Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_download"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dialog_button_height"
            android:text="Download Update"
            android:textSize="@dimen/dialog_button_text_size"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_color"
            app:cornerRadius="@dimen/dialog_button_corner_radius"
            app:icon="@drawable/ic_arrow_forward"
            app:iconTint="@color/white"
            app:iconSize="@dimen/dialog_button_icon_size"
            android:layout_marginTop="@dimen/dialog_button_margin_top"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

</LinearLayout>

</ScrollView>

</androidx.cardview.widget.CardView>