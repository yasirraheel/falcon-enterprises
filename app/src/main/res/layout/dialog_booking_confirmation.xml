<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_background"
    android:padding="24dp">

    <!-- Header Icon -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/primary_color">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_orders"
                android:contentDescription="Order Icon"
                android:tint="@color/white" />

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Booking"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Order Details Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/card_background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Game & Bond Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:minWidth="60dp" />

                <TextView
                    android:id="@+id/tv_booking_game"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pakistan Prize Bond"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bond:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:minWidth="60dp" />

                <TextView
                    android:id="@+id/tv_booking_bond"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bond 1 Muzafarabad"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginVertical="6dp" />

            <!-- RTTP Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTTP:"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:minWidth="60dp" />

                <TextView
                    android:id="@+id/tv_booking_rttp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="123456"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="monospace" />

            </LinearLayout>

            <!-- Numbers & Amounts in One Row (Grid) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:weightSum="3">

                <!-- First -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="First"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_booking_first"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₨ 1,000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <!-- Second -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Second"
                        android:textSize="10sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_booking_second"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₨ 2,000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <!-- Total -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textSize="10sp"
                        android:textColor="@color/primary_color"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_booking_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₨ 3,000"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color" />

                </LinearLayout>

            </LinearLayout>

            <!-- Dealer Commission Info -->
            <LinearLayout
                android:id="@+id/ll_booking_commission_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E8F5E9"
                android:padding="8dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="2dp">
                    
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="You will pay:"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                        
                    <TextView
                        android:id="@+id/tv_booking_payable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₨ 450"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/success_dark" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_booking_commission_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="₨ 50 is your commission (10%)"
                    android:textSize="11sp"
                    android:textColor="@color/success_dark" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_color"
                android:layout_marginVertical="6dp" />

            <!-- Balance Info (Compact) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Current Balance:"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_booking_current_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₨ 10,000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/success_color" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="After Booking:"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_booking_after_balance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₨ 7,000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/warning_color" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Confirmation Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proceed with this booking?"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_booking_cancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:backgroundTint="@android:color/transparent"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            app:cornerRadius="24dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_booking_confirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Book Now"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:backgroundTint="@color/primary_color"
            android:textAllCaps="false"
            android:layout_marginStart="8dp"
            app:cornerRadius="24dp"
            app:elevation="4dp" />

    </LinearLayout>

</LinearLayout>
