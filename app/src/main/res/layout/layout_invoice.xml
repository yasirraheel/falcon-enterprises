<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/white"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="6dp"
    android:paddingBottom="4dp">

    <!-- App Branding Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <!-- App Logo -->
        <ImageView
            android:id="@+id/iv_invoice_logo"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="App Logo"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/tv_invoice_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GEO ENTERPRISES"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_color"
            android:layout_marginBottom="1dp" />

        <TextView
            android:id="@+id/tv_invoice_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Prize Bond Booking System"
            android:textSize="9sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/primary_color"
        android:layout_marginBottom="4dp" />

    <!-- Invoice Title -->
    <TextView
        android:id="@+id/tv_invoice_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VOUCHER"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="4dp" />

    <!-- User Information -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_primary"
        android:padding="6dp"
        android:layout_marginBottom="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:text="Customer:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_invoice_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Doe"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">

            <TextView
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:text="Phone:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_invoice_user_phone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="+92 300 1234567"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="65dp"
                android:layout_height="wrap_content"
                android:text="Date:"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tv_invoice_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025-10-11"
                android:textSize="9sp"
                android:textColor="@color/text_primary" />

        </LinearLayout>

    </LinearLayout>

    <!-- Orders Table Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_color"
        android:paddingStart="3dp"
        android:paddingEnd="3dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:text="ID"
            android:textSize="8sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="start"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1"
            android:visibility="gone" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.7"
            android:text="Bond"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="start"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RTTP"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:text="First"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="end"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:text="Second"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="end"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="end"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:text="Status"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1" />

    </LinearLayout>

    <!-- Orders Container (will be populated dynamically) -->
    <LinearLayout
        android:id="@+id/ll_invoice_orders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color"
        android:layout_marginVertical="2dp" />

    <!-- Total Amount -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/primary_color"
        android:padding="6dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="TOTAL AMOUNT:"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/tv_invoice_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₨ 0"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white" />

    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Thank you for your business!"
        android:textSize="7sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="4dp" />

</LinearLayout>
