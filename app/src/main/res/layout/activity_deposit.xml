<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary">

    <!-- Top Bar (Sticky Header) -->
    <LinearLayout
        android:id="@+id/top_bar"
        style="@style/WidgetGeoTopBar">

        <ImageView
            android:id="@+id/iv_back"
            style="@style/WidgetGeoTopBarNavIcon"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back" />

        <TextView
            style="@style/TextAppearanceGeoTopBarTitle"
            android:text="Deposit Funds"
            />

    </LinearLayout>

    <!-- Content ScrollView -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Instructions Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <TextView
                        android:id="@+id/tv_how_to_deposit_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ڈیپوزٹ کرنے کا طریقہ"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color"
                        android:fontFamily="@font/noto_nastaliq_urdu"
                        android:includeFontPadding="true"
                        android:layoutDirection="rtl"
                        android:textDirection="rtl"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_how_to_deposit_steps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="۱. ادائیگی کا طریقہ منتخب کریں\n۲. دیئے گئے اکاؤنٹ میں رقم منتقل کریں\n۳. ٹرانزیکشن آئی ڈی درج کریں\n۴. ادائیگی کا ثبوت اپلوڈ کریں\n۵. تصدیق کے لیے جمع کروائیں"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/noto_nastaliq_urdu"
                        android:includeFontPadding="true"
                        android:lineSpacingMultiplier="1.0"
                        android:layoutDirection="rtl"
                        android:textDirection="rtl" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Payment Method Dropdown -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Select Payment Method *"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinner_payment_method"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="12dp"
                android:paddingEnd="40dp"
                android:layout_marginBottom="16dp" />

            <!-- Payment Method Details Card (Initially Hidden) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_payment_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Bank Logo -->
                    <ImageView
                        android:id="@+id/iv_bank_logo"
                        android:layout_width="120dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center_horizontal"
                        android:scaleType="fitCenter"
                        android:layout_marginBottom="12dp"
                        android:contentDescription="Bank Logo" />

                    <!-- Bank Name -->
                    <TextView
                        android:id="@+id/tv_bank_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="JazzCash Account"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="12dp" />

                    <!-- Account Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Account Title:"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_account_title"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Muhammad Shahab"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:gravity="end" />

                    </LinearLayout>

                    <!-- Account Number -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Account No:"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <LinearLayout
                            android:id="@+id/ll_copy_account"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="end|center_vertical"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="4dp">

                            <TextView
                                android:id="@+id/tv_account_no"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="032546566272"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:fontFamily="monospace"
                                android:layout_marginEnd="8dp" />

                            <ImageView
                                android:id="@+id/iv_copy_account"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_copy"
                                android:background="?android:attr/selectableItemBackgroundBorderless"
                                android:padding="2dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:contentDescription="Copy Account Number"
                                android:tint="@color/primary_color" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Deposit Limits -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_input">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Min Limit:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_min_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₨ 0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:layout_marginEnd="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Max Limit:"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_max_limit"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₨ 0"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:layout_marginStart="4dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Amount Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Amount *"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_amount_urdu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="اپنی اماؤنٹ درج کریں"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"
                    android:fontFamily="@font/noto_nastaliq_urdu"
                    android:includeFontPadding="true"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:gravity="end"
                    android:layoutDirection="rtl"
                    android:textDirection="rtl" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_amount"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:hint="Enter amount"
                android:inputType="number"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:layout_marginBottom="16dp" />

            <!-- Transaction ID Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Transaction ID *"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_transaction_id_urdu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ٹرانزیکشن آئی ڈی درج کریں"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_color"
                    android:fontFamily="@font/noto_nastaliq_urdu"
                    android:includeFontPadding="true"
                    android:lineSpacingExtra="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:gravity="end"
                    android:layoutDirection="rtl"
                    android:textDirection="rtl" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_transaction_id"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:hint="Enter transaction ID"
                android:inputType="text"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:layout_marginBottom="16dp" />

            <!-- Payment Proof Upload -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Payment Proof (Screenshot/Photo) *"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tv_payment_proof_urdu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اپنی ٹرانزیکشن کا پیمنٹ پروف سکرین شاٹ اپلوڈ کریں"
                android:textSize="13sp"
                android:textColor="@color/primary_color"
                android:textStyle="bold"
                android:fontFamily="@font/noto_nastaliq_urdu"
                android:includeFontPadding="true"
                android:lineSpacingExtra="4dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layoutDirection="rtl"
                android:textDirection="rtl"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_choose_file"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="Choose File"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primary_color"
                    android:textAllCaps="false"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_upload"
                    app:iconTint="@color/white"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_file_name"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:text="No file chosen"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:ellipsize="end"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- Preview Image (Hidden initially) -->
            <ImageView
                android:id="@+id/iv_payment_proof_preview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_input"
                android:contentDescription="Payment Proof Preview" />

            <!-- Important Notice Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFF9E6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <TextView
                        android:id="@+id/tv_important_notice_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="⚠️ اہم اطلاع"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FF8C00"
                        android:fontFamily="@font/noto_nastaliq_urdu"
                        android:includeFontPadding="true"
                        android:layoutDirection="rtl"
                        android:textDirection="rtl"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_important_notice_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ادائیگی کے ثبوت کی تصدیق کے بعد آپ کا ڈیپوزٹ 30 منٹ کے اندر تصدیق ہو جائے گا۔"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/noto_nastaliq_urdu"
                        android:includeFontPadding="true"
                        android:layoutDirection="rtl"
                        android:textDirection="rtl" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Submit Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="ڈیپوزٹ درخواست جمع کروائیں"
                android:textSize="14sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary_color"
                android:textAllCaps="false"
                android:fontFamily="@font/noto_nastaliq_urdu"
                app:fontFamily="@font/noto_nastaliq_urdu"
                android:includeFontPadding="true"
                android:layoutDirection="rtl"
                android:textDirection="rtl"
                app:cornerRadius="8dp"
                app:elevation="4dp"
                android:layout_marginTop="8dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>

