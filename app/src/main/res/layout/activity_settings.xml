<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_primary"
    tools:context=".settings.SettingsActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/top_bar"
        style="@style/WidgetGeoTopBar">

        <ImageView
            android:id="@+id/iv_back"
            style="@style/WidgetGeoTopBarNavIcon"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            style="@style/TextAppearanceGeoTopBarTitle"
            android:text="Settings"
            />

    </LinearLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Account Settings Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Settings"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Profile Image Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iv_profile_image"
                                android:layout_width="80dp"
                                android:layout_height="80dp"
                                android:background="@drawable/circular_image_background"
                                android:scaleType="centerCrop"
                                android:adjustViewBounds="false"
                                android:padding="2dp"
                                android:src="@drawable/ic_account"
                                android:contentDescription="Profile Image" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="16dp">

                                <TextView
                                    android:id="@+id/tv_profile_name"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Profile Name"
                                    android:textSize="16sp"
                                    android:textColor="@color/text_primary"
                                    android:textStyle="bold" />

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="4dp">

                                    <TextView
                                        android:id="@+id/tv_profile_phone"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="+92..."
                                        android:textSize="12sp"
                                        android:textColor="@color/text_secondary" />

                                </LinearLayout>

                                <!-- Dealer Badge -->
                                <LinearLayout
                                    android:id="@+id/ll_dealer_badge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="4dp"
                                    android:background="@drawable/bg_premium_badge"
                                    android:paddingStart="6dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:visibility="gone">

                                    <ImageView
                                        android:layout_width="16dp"
                                        android:layout_height="16dp"
                                        android:src="@drawable/ic_verified"
                                        app:tint="@color/primary_color"
                                        android:layout_marginEnd="4dp" />

                                    <TextView
                                        android:id="@+id/tv_dealer_badge_text"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Dealer"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/black"
                                        android:singleLine="true" />

                                </LinearLayout>

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_change_image"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:text="Change"
                                android:textSize="12sp"
                                android:textColor="@color/primary_color"
                                android:backgroundTint="@android:color/transparent"
                                android:textAllCaps="false"
                                app:cornerRadius="18dp"
                                style="@style/Widget.Material3.Button.OutlinedButton" />

                        </LinearLayout>

                        <!-- Old Dealer Badge Row Removed -->

                    </LinearLayout>

                    <!-- Name Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Full Name"
                        app:boxStrokeColor="@color/primary_color"
                        app:hintTextColor="@color/primary_color"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/primary_color">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Phone Number"
                        app:boxStrokeColor="@color/primary_color"
                        app:hintTextColor="@color/primary_color"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/primary_color">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- City Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="City"
                        app:boxStrokeColor="@color/primary_color"
                        app:hintTextColor="@color/primary_color"
                        app:startIconDrawable="@drawable/ic_location"
                        app:startIconTint="@color/primary_color">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_city"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="New Password (Optional)"
                        app:boxStrokeColor="@color/primary_color"
                        app:hintTextColor="@color/primary_color"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="@color/primary_color"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/primary_color">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Update Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_update_profile"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Update Profile"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary_color"
                        android:textAllCaps="false"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="24dp"
                        app:elevation="4dp" />

                    <!-- Logout Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_logout"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Logout"
                        android:textSize="14sp"
                        android:textColor="@color/error"
                        android:backgroundTint="@android:color/transparent"
                        android:textAllCaps="false"
                        android:layout_marginTop="12dp"
                        app:cornerRadius="24dp"
                        app:strokeColor="@color/error"
                        app:strokeWidth="1dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>



        </LinearLayout>

    </ScrollView>

    <!-- Bottom Navigation -->
    <include layout="@layout/bottom_navigation" />

</LinearLayout>

